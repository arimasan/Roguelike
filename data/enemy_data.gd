static func get_by_id(enemy_id: String) -> Dictionary:
	for e in ALL:
		if e.get("id", "") == enemy_id:
			return e.duplicate(true)
	return {}

static func for_floor(floor_num: int) -> Array:
	var result: Array = []
	for e in ALL:
		if floor_num >= e["floor_min"] and floor_num <= e["floor_max"]:
			result.append(e)
	return result
